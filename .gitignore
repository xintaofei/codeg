# Logs
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
tsconfig.tsbuildinfo

# Next.js
.next/
out/
next-env.d.ts

# Monaco editor local files (copied from node_modules)
public/vs

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test artifacts
coverage/
*.snap.new
.vitest-cache/

# macOS signing material. Keep certificates and exported private keys out of git.
*.cer
*.csr
*.p12
certificate-base64.txt

# Android signing material. Release credentials are injected from the local
# keychain or CI and must never be committed.
*.jks
*.keystore
keystore.properties

# Agent
.claude
.docs
docs/superpowers

# Tauri sidecar staging (built per-target by prepare-sidecars.mjs).
# The binaries are platform-specific build artifacts; ship them through
# release.yml, not git.
src-tauri/binaries/
mobile/src-tauri/target/
relay/target/

# pnpm local store (pnpm 11+)
.pnpm-store/
