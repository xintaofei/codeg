# Bind only inside the container. Docker publishes this as 127.0.0.1:18787.
CODEG_RELAY_BIND=0.0.0.0:8787
CODEG_RELAY_CREDENTIAL_FILE=/data/device-credentials.json

# Generate a token with: openssl rand -hex 32
# A private single-user deployment may use "*" because the desktop ID is
# generated by Codeg. Multi-user deployments should provision explicit IDs.
CODEG_RELAY_DESKTOP_TOKENS={"*":"replace-with-at-least-32-random-characters"}

CODEG_RELAY_MAX_FRAME_BYTES=1048576
RUST_LOG=codeg_relay=info
