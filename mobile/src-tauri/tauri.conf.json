{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codeg Mobile",
  "version": "0.20.3",
  "identifier": "cn.crain.codeg.mobile",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev",
    "devUrl": "http://10.0.2.2:3000",
    "beforeBuildCommand": "pnpm --dir .. build",
    "frontendDist": "../../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codeg Mobile",
        "width": 390,
        "height": 844,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
